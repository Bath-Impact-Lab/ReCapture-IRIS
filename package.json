{
  "name": "iris-starter-project",
  "version": "0.1.4",
  "description": "Electron starter app for IRIS with Three.js and camera selection UI",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron --inspect=9229 --remote-debugging-port=9222 .\"",
    "dev:renderer": "vite",
    "build:renderer": "cross-env vite build",
    "build:web": "cross-env vite build",
    "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build:renderer && electron-builder --win --x64",
    "start": "electron .",
    "lint": "echo 'No linter configured'",
    "check:deps": "npx npm-check-updates",
    "wait:9222": "wait-on tcp:9222"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "dotenv": "^17.3.1",
    "echarts": "^6.0.0",
    "node-pty": "^1.1.0",
    "onnxruntime-node": "^1.24.3",
    "pinia": "^3.0.4",
    "three": "0.169.0",
    "vue": "^3.5.31",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "@types/node": "^24.9.0",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-vue": "6.0.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "40.6.1",
    "electron-builder": "^26.8.1",
    "npm-check-updates": "^17.1.0",
    "typescript": "^5.6.2",
    "vite": "^7.3.1",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.bath-impact-lab.iris-app",
    "productName": "IRIS App",
    "forceCodeSigning": false,
    "files": [
      "dist/**",
      "electron/**"
    ],
    "extraResources": [
      {
        "from": "public/assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
